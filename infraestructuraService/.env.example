# Base de datos
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_bd?schema=public

# Puerto del servidor
PORT=3006

# Modo desarrollo (false en produccion)
ALLOW_DEV_MOCK=false

# Clave publica JWT (copiar contenido del archivo config/public.pem)
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# SMTP para envio de correos
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=correo@ejemplo.com
SMTP_PASS=contraseña
